                if (item !== answer) {
                    item.classList.remove('active');
                    item.previousElementSibling.querySelector('span').textContent = '▼';
                }
            });
            
            // Toggle current
            answer.classList.toggle('active');
            arrow.textContent = answer.classList.contains('active') ? '▲' : '▼';
        }
